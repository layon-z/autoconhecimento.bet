# ============================================================
# Variáveis de ambiente — copie pra Vercel (Settings > Environment Variables)
# ============================================================

# --- Supabase (obrigatório) ---
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=cole-aqui-a-service-role-key

# --- Segredo da sessão (invente uma frase longa e aleatória) ---
SESSION_SECRET=troque-por-uma-frase-bem-grande-e-aleatoria-123

# --- Quem é o admin (nome usado no login, em minúsculas) ---
ADMIN_NAME=edu

# --- Saldo inicial de cada jogador (R$ fictício) ---
START_BALANCE=50

# --- Dados reais da Copa (opcional). Sem isso, usa jogos de exemplo. ---
# Pegue grátis em https://www.football-data.org/client/register
FOOTBALL_DATA_KEY=

# --- Segredo do cron (opcional, a Vercel preenche sozinha se você criar) ---
CRON_SECRET=
